GITHUB_TOKEN=github_pat_or_app_user_token
GITHUB_DEFAULT_ORG=
GITHUB_API_VERSION=2026-03-10
GITHUB_BASE_URL=https://api.github.com
GITHUB_GRAPHQL_URL=https://api.github.com/graphql
GITHUB_USE_SYSTEM_CERT_STORE=true
GITHUB_SSL_VERIFY=true
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# GitHub OAuth App settings.
# Create an OAuth App in GitHub Developer settings with callback:
# http://127.0.0.1:8000/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=your_oauth_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_app_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/github/callback
GITHUB_OAUTH_SCOPES=read:user,user:email,read:org,repo
FRONTEND_URL=http://127.0.0.1:5173
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_COOKIE_NAME=air_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800

# Optional dashboard defaults. Leave blank to include all issues.
GITHUB_ISSUE_LABEL_FILTER=
GITHUB_AUTOMATION_BOT_LOGIN=airp-automation-bot
GITHUB_AGENT_PR_LABEL_FILTER=agentic-remediation,ai-remediation
