AIRP_APP_NAME="AIRP Backend API"
AIRP_ENVIRONMENT=development
AIRP_LOG_LEVEL=INFO
AIRP_DATABASE_URL=postgresql+asyncpg://airp:airp@localhost:5432/airp
AIRP_POSTGRES_PORT=5432
AIRP_REDIS_URL=redis://localhost:6379/0
AIRP_ALLOWED_ORIGINS=[]
AIRP_API_MAX_REQUEST_BODY_BYTES=1048576
AIRP_READINESS_PROBE_TIMEOUT_SECONDS=10

# Microsoft Entra ID auth. These are required when AIRP_AUTH_ENABLED=true.
AIRP_AUTH_ENABLED=true
AIRP_ENTRA_TENANT_ID=
AIRP_ENTRA_CLIENT_ID=
AIRP_ENTRA_ALLOWED_ISSUERS=[]
AIRP_ENTRA_DISCOVERY_CACHE_TTL_SECONDS=3600
AIRP_ENTRA_DISCOVERY_TIMEOUT_SECONDS=5

# GenAI Hub
AIRP_GATEWAY_BASE_URL=
AIRP_GATEWAY_API_KEY=
AIRP_LLM_MONITORING_MODEL=gpt-4.1-nano
AIRP_LLM_CORRELATION_MODEL=gpt-4.1
AIRP_LLM_RCA_MODEL=gpt-5.2-CIO
AIRP_LLM_REMEDIATION_MODEL=gpt-5.2-CIO
AIRP_LLM_DOCUMENTATION_MODEL=gpt-4.1
AIRP_LLM_EMBEDDING_MODEL=embeddings

# Read-only evidence MCP integrations
AIRP_AGENT_READ_ONLY_EVIDENCE_ENABLED=true
AIRP_KUBERNETES_MCP_TRANSPORT=mcp
AIRP_KUBERNETES_MCP_URL=http://kubernetes-mcp:8080
AIRP_KUBERNETES_MCP_NAMESPACE_ALLOWLIST=["shopfast","payments","catalog"]
AIRP_KUBERNETES_MCP_READ_TIMEOUT_SECONDS=20
AIRP_GITHUB_MCP_TRANSPORT=mcp
AIRP_GITHUB_MCP_URL=http://github-mcp:8080
AIRP_GITHUB_MCP_REPOSITORY_ALLOWLIST=["AIRP-client/*"]
AIRP_GITHUB_MCP_READ_TIMEOUT_SECONDS=20
AIRP_MCP_READ_RETRY_ATTEMPTS=2
AIRP_MCP_READ_RETRY_MIN_BACKOFF_SECONDS=0.1
AIRP_MCP_READ_RETRY_MAX_BACKOFF_SECONDS=1.0

# Azure Event Hubs Kafka-compatible endpoint
AIRP_KAFKA_BOOTSTRAP_SERVERS=
AIRP_KAFKA_SECURITY_PROTOCOL=SASL_SSL
AIRP_KAFKA_SASL_MECHANISM=PLAIN
AIRP_KAFKA_USERNAME='$ConnectionString'
AIRP_KAFKA_PASSWORD=
AIRP_KAFKA_ALERTS_RAW_TOPIC=airp.alerts.raw
AIRP_KAFKA_INCIDENTS_VALIDATED_TOPIC=airp.incidents.validated
AIRP_KAFKA_DEADLETTER_TOPIC=airp.deadletter
AIRP_KAFKA_ALERT_CONSUMER_GROUP=airp-alert-consumer
AIRP_ALERT_DEDUPE_TTL_SECONDS=3600

# Temporal
AIRP_TEMPORAL_ADDRESS=localhost:7233
AIRP_TEMPORAL_NAMESPACE=default
AIRP_TEMPORAL_TASK_QUEUE=airp-incident-workflows
AIRP_TEMPORAL_TLS=false
AIRP_TEMPORAL_START_WORKFLOWS=true
